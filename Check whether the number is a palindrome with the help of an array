#include <stdio.h>
int main() {
    int n, temp, digit, arr[20], i = 0, j, isPalindrome = 1;
    printf("Enter a number: ");
    scanf("%d", &n);
    temp = n;
    // Store digits in array
    while (temp > 0) {
        digit = temp % 10;
        arr[i] = digit;
        temp = temp / 10;
        i++;
    }

    // Check palindrome
    for (j = 0; j < i / 2; j++) {
        if (arr[j] != arr[i - j - 1]) {
            isPalindrome = 0;
            break;
        }
    }

    // Output result
    if (isPalindrome)
        printf("Palindrome number");
    else
        printf("Not a palindrome");

    return 0;
}
