#include <stdio.h>

// recursive function to calculate power
int power(int x, int y)
{
    if (y == 0)
        return 1;        // base case
    else
        return x * power(x, y - 1);   // recursive call
}

int main()
{
    int x, y, result;

    printf("Enter value of x: ");
    scanf("%d", &x);

    printf("Enter value of y: ");
    scanf("%d", &y);

    result = power(x, y);

    printf("%d^%d = %d", x, y, result);

    return 0;
}
